# Dependencies — installed fresh from package.json on the server
node_modules/

# Build output — regenerated by `npm run build` on every deploy
dist/
dist-ssr/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor & OS junk
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# Local-only env files (in case you ever add one)
.env
.env.local
.env.*.local

# Cloudflare Pages / Vite cache
.wrangler/
.vite/

# TypeScript incremental build cache (machine-specific)
*.tsbuildinfo
