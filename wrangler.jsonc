{
  "$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
  "name": "reading-app",
  "compatibility_date": "2024-12-01",
  "workers_dev": true,
  "routes": [
    { "pattern": "starator.com", "custom_domain": true }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
